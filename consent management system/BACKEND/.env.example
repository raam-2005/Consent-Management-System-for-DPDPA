# ============================================
# DPDPA CMS - Environment Configuration
# ============================================
# Copy this file to .env and configure values
# NEVER commit .env file to version control!
# ============================================

# ============================================
# DJANGO CORE SETTINGS
# ============================================

# SECURITY: Generate a strong secret key using:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-this-in-production-dpdpa-consent-system

# DEVELOPMENT: True | PRODUCTION: False
DEBUG=True

# Comma-separated list of allowed hosts
# DEVELOPMENT: localhost,127.0.0.1
# PRODUCTION: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO

# ============================================
# DATABASE CONFIGURATION
# ============================================
# SQLite is default (no config needed for development)
# For production, use PostgreSQL:
# DATABASE_URL=postgres://user:password@localhost:5432/dpdpa_cms

# ============================================
# CORS CONFIGURATION (Production)
# ============================================
# Comma-separated list of allowed frontend origins
# Leave blank to use defaults from settings.py
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# EMAIL CONFIGURATION
# ============================================
# For development, emails are printed to console (no config needed)
# For production, configure SMTP settings:

# Gmail SMTP Example:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password  # Use App Password, not regular password
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# DEFAULT_FROM_EMAIL=your-email@gmail.com

# Outlook/Office365 SMTP Example:
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@outlook.com
# EMAIL_HOST_PASSWORD=your-password
# EMAIL_USE_TLS=True

# Custom SMTP Server:
# EMAIL_HOST=mail.yourdomain.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@yourdomain.com
# EMAIL_HOST_PASSWORD=your-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Admin email for error notifications
ADMIN_EMAIL=admin@example.com

# ============================================
# SECURITY (Production Only)
# ============================================
# These are automatically enabled when DEBUG=False:
# - SECURE_SSL_REDIRECT=True (force HTTPS)
# - SECURE_HSTS_SECONDS=31536000 (1 year HSTS)
# - SESSION_COOKIE_SECURE=True
# - CSRF_COOKIE_SECURE=True
# - X_FRAME_OPTIONS=DENY

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to production:
# [ ] Set DEBUG=False
# [ ] Generate and set strong SECRET_KEY
# [ ] Update ALLOWED_HOSTS with your domain
# [ ] Configure database (PostgreSQL recommended)
# [ ] Set up SMTP email
# [ ] Configure CORS for your frontend domain
# [ ] Run: python manage.py check --deploy
# [ ] Run: python manage.py collectstatic
# [ ] Set up HTTPS with SSL certificate
# [ ] Configure Gunicorn or similar WSGI server
# [ ] Set up Nginx as reverse proxy
